---
import DefaultPageTitle from '@astrojs/starlight/components/PageTitle.astro';

const { entry, title, frontmatter } = Astro.props;

const { author, publishDate, coverImage } = frontmatter ?? {};

// Check if the page is either in the news/ folder OR the homilies/ folder
const isNewsOrHomily =
  entry &&
  (entry.id.startsWith('news/') || entry.id.startsWith('about-us/homilies/')) &&
  !entry.id.endsWith('index');

const currentUrl = encodeURIComponent(Astro.url.href);
const encodedTitle = encodeURIComponent(title || 'Diocese of Kalookan');

const fbShare = `https://www.facebook.com/sharer/sharer.php?u=${currentUrl}`;
const xShare = `https://twitter.com/intent/tweet?url=${currentUrl}&text=${encodedTitle}`;
const pinShare = `https://pinterest.com/pin/create/button/?url=${currentUrl}&description=${encodedTitle}`;
---
<DefaultPageTitle {...Astro.props} />

{isNewsOrHomily && (
  <div class="news-header">
    <div class="news-meta">
      {publishDate && (
        <time datetime={publishDate.toISOString()}>
          📅 {publishDate.toLocaleDateString('en-US', { dateStyle: 'long' })}
        </time>
      )}
      {author && <span>✍️ {author}</span>}
    </div>
    
    <div class="share-row">
      <span class="share-label">Share this:</span>
      <a href={fbShare} target="_blank" rel="noopener noreferrer" class="share-btn fb">Facebook</a>
      <a href={xShare} target="_blank" rel="noopener noreferrer" class="share-btn x">X (Twitter)</a>
      <a href={pinShare} target="_blank" rel="noopener noreferrer" class="share-btn pin">Pinterest</a>
    </div>

    {coverImage && (
      <img
        src={coverImage}
        alt={title}
        class="hero-img"
      />
    )}

    <hr />
  </div>
)}

<style>
  .news-header { margin-bottom: 2rem; }
  .news-meta { 
    display: flex; 
    gap: 1.5rem; 
    color: var(--sl-color-gray-3); 
    font-size: 0.9rem; 
    margin-top: -0.5rem; 
    margin-bottom: 1.5rem; 
  }
  .hero-image-container { 
    border-radius: var(--sl-border-radius-large); 
    overflow: hidden; 
    box-shadow: var(--sl-shadow-md); 
    margin-bottom: 1.5rem; 
  }
  .hero-img { 
    width: 100%; 
    height: auto; 
    display: block; 
    object-fit: cover; 
  }
  .news-divider { 
    border: 0; 
    border-top: 1px solid var(--sl-color-gray-5); 
  }

.share-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .share-label {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    font-weight: 600;
  }

  .share-btn {
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    text-decoration: none;
    color: white;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .share-btn:hover {
    opacity: 0.8;
  }

  /* Brand Colors */
  .fb { background-color: #1877F2; }
  .x { background-color: #000000; border: 1px solid #333; }
  .pin { background-color: #E60023; }
</style>