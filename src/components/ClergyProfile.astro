---
import { Image } from 'astro:assets';
const { name, img, parish, position } = Astro.props;
---

<div class="station-card-container">
  <div class="bg-image-wrapper">
    {typeof img === 'string' ? (
      <img src={img} alt={name} class="overlay-zoom-img" />
    ) : (
      <Image src={img} alt={name} class="overlay-zoom-img" />
    )}
  </div>
  
  <div class="text-overlay">
    {/* Position */}
    <span class="position-tag">{position}</span>
    
    <h3 class="priest-name">
      {name}
    </h3>
    
    <div class="parish-footer">
        <div class="parish-content">
          <span>{parish}</span>
        </div>
    </div>
  </div>
</div>

<style>
  .station-card-container {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    height: 300px;
    border: 1px solid var(--sl-color-gray-5);
    transition: all 0.3s ease;
    display: flex; 
    flex-direction: column;
    justify-content: flex-end;
    cursor: pointer;
    background: rgb(80, 4, 4)
  }

  .station-card-container:hover {
    border-color: #d4af37; 
    box-shadow: var(--sl-shadow-lg);
    transform: translateY(-4px);
  }

  .bg-image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; 
  }

  .overlay-zoom-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
    transition: transform 0.6s cubic-bezier(0.25, 0.45, 0.45, 0.95);
  }

  .station-card-container:hover .overlay-zoom-img {
    transform: scale(1.1);
    opacity: 1;
  }

  .text-overlay {
    position: relative;
    z-index: 2; 
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.6) 50%, transparent 100%);
    width: 100%;
  }

  .position-tag {
    color: #d4af37;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    display: block;
    margin-bottom: 0.2rem;
  }

  .priest-name {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0 !important;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    line-height: 1.2;
    font-family: 'Playfair Display', serif;
  }

  .parish-footer {
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 0.75rem;
  }

  .parish-content {
    font-size: 0.75rem;
    display: flex;
    align-items: start;
    gap: 0.4rem;
    color: #cbd5e1;
    font-style: italic;
  }

  .unavailable {
    font-size: 0.7rem;
    color: #94a3b8;
    font-style: italic;
  }

  :global(.clergy-grid) {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin: 2rem 0;
  align-items: start;
}

:global(.clergy-grid p) {
  display: contents;
  margin: 0;
}

:global(.clergy-grid > *) {
  margin: 0 !important;
}

@media (max-width: 1024px) {
    :global(.clergy-grid) {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 640px) {
    :global(.clergy-grid) {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  
</style>

